rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - stats: map (optional)
    //   - activeAgentId: string (optional)
    //   - currentRoadmapId: string (optional)
    //
    // Collection: agents
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - userId: string (required, Auth UID)
    //   - ... (other agent fields)
    //
    // Collection: roadmaps
    // Fields:
    //   - id: string (required)
    //   - userId: string (required, Auth UID)
    //   - ... (other roadmap fields)
    //
    // Collection: notes
    // Fields:
    //   - id: string (required)
    //   - userId: string (required, Auth UID)
    //   - ... (other note fields)
    //
    // Collection: messages
    // Fields:
    //   - id: string (required)
    //   - userId: string (required, Auth UID)
    //   - ... (other message fields)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kartunkutv22@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /agents/{agentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /roadmaps/{roadmapId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /notes/{noteId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
